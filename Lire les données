import psycopg2

conn = psycopg2.connect(
    host="localhost",
    database="postgres",
    user="postgres",
    password="1234"
)

cur = conn.cursor()

cur.execute("SELECT * FROM famous_programmers")

rows = cur.fetchall()

for row in rows:
    print(f"ID: {row[0]} | Nom: {row[1]} | Langage: {row[2]}")

cur.close()
conn.close()
