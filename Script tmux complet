#!/bin/bash

SESSION="super_guestbook"

# 1️⃣ Crée une nouvelle session détachée
tmux new-session -d -s $SESSION -n editor

# 2️⃣ Panneau 1 : Éditeur (Left)
tmux send-keys -t $SESSION "vim app.py" C-m

# 3️⃣ Split vertical pour panneau serveur (Top Right)
tmux split-window -h -t $SESSION
tmux send-keys -t $SESSION:0.1 "python app.py" C-m

# 4️⃣ Split horizontal pour base de données (Middle Right)
tmux split-window -v -t $SESSION:0.1
tmux send-keys -t $SESSION:0.2 "psql -U quiz_user -d quizdb" C-m

# 5️⃣ Split horizontal pour logs IA (Bottom Right)
tmux split-window -v -t $SESSION:0.2
tmux send-keys -t $SESSION:0.3 "tail -f logs/ai_moderation.log" C-m

# 6️⃣ Ajuste la disposition pour tous les panneaux
tmux select-layout -t $SESSION tiled

# 7️⃣ Message d’accueil dans chaque panneau
tmux send-keys -t $SESSION:0.0 "echo 'Éditeur code'" C-m
tmux send-keys -t $SESSION:0.1 "echo 'Serveur Python en cours...'" C-m
tmux send-keys -t $SESSION:0.2 "echo 'Console DB prête'" C-m
tmux send-keys -t $SESSION:0.3 "echo 'Logs IA modération'" C-m

# 8️⃣ Rattache la session automatiquement
tmux attach-session -t $SESSION
