import hashlib

@app.route("/register", methods=["POST"])
def register():
    data = request.json
    username = data["username"]
    password = hashlib.sha256(data["password"].encode()).hexdigest()

    conn = get_connection()
    cur = conn.cursor()

    cur.execute(
        "INSERT INTO users (username, password) VALUES (%s, %s)",
        (username, password)
    )
    conn.commit()

    return jsonify({"status": "user created"})
