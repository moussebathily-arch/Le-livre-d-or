version: "3.9"

services:
  app:
    build: .
    ports:
      - "5000:5000"
    depends_on:
      - db

  db:
    image: postgres:15
    environment:
      POSTGRES_USER: guest_user
      POSTGRES_PASSWORD: guest_pass
      POSTGRES_DB: guestbook
    volumes:
      - ./db/init.sql:/docker-entrypoint-initdb.d/init.sql
