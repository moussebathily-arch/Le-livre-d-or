import tkinter as tk
import psycopg2

class DashboardFrame(tk.Frame):
    def __init__(self, parent, conn):
        super().__init__(parent)
        self.conn = conn

        # Titre visible
        tk.Label(self, text="Tableau de bord en direct", font=("Arial", 18, "bold")).pack(pady=20)

        # Étiquette de statistiques initialement vide
        self.stats_lbl = tk.Label(self, text="", font=("Arial", 14))
        self.stats_lbl.pack(pady=10)

        # Bouton pour actualiser manuellement
        tk.Button(self, text="Actualiser", command=self.fetch_stats).pack(pady=5)

        # Charger les stats dès l'ouverture
        self.fetch_stats()

    def fetch_stats(self):
        """Récupère le total des questions depuis PostgreSQL"""
        if not self.conn:
            self.stats_lbl.config(text="Impossible de se connecter à la DB")
            return

        try:
            cur = self.conn.cursor()
            cur.execute("SELECT COUNT(*) FROM questions;")
            count = cur.fetchone()[0]
            self.stats_lbl.config(text=f"Nombre total de questions : {count}")
            cur.close()
        except Exception as e:
            self.stats_lbl.config(text=f"Erreur DB : {e}")
